rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.size() >= 3 &&
             data.id is string && data.id == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('whatsappNumber' in data) || (data.whatsappNumber is string && data.whatsappNumber.size() <= 20));
    }

    function isValidItem(data) {
      return data.size() >= 5 &&
             data.id is string &&
             data.sellerId is string && data.sellerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             data.price is number && data.price >= 0 &&
             data.categoryId is string &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('imageUrls' in data) || (data.imageUrls is list && data.imageUrls.size() <= 10)) &&
             (!('status' in data) || (data.status in ['available', 'sold']));
    }

    function isValidCategory(data) {
      return data.size() >= 2 &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50;
    }

    function isValidCart(data) {
      return data.size() >= 3 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.itemId is string &&
             data.quantity is number && data.quantity > 0;
    }

    // --- Collection Rules ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == "user"; // Beginners can't make themselves admins
      allow update: if (isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role) || isAdmin();
      allow delete: if isAdmin();
    }

    // ITEMS
    match /items/{itemId} {
      allow read: if true; // Public listings
      allow create: if isVerified() && isValidItem(incoming()) && exists(/databases/$(database)/documents/categories/$(incoming().categoryId));
      allow update: if (isSignedIn() && isOwner(existing().sellerId) && isValidItem(incoming())) || isAdmin();
      allow delete: if (isSignedIn() && isOwner(existing().sellerId)) || isAdmin();
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming());
    }

    // WISHLIST
    match /wishlist/{wishId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update: if false; // Wishlist items are generally added/removed, not updated
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // CART
    match /cart/{cartId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isVerified() && isValidCart(incoming());
      allow update: if (isSignedIn() && isOwner(existing().userId) && isValidCart(incoming()));
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }
  }
}
